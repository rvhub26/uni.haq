# Server
PORT=3002
NODE_ENV=development
SESSION_SECRET=your_session_secret_minimum_32_chars

# Database (MySQL)
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=unihaq

# Claude AI Brain (closing-bot, optional per device)
CLAUDE_API_KEY=your_claude_api_key

# Telegram notifications (closing-bot, optional per device fallback)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Meta Cloud API webhook verify token
META_VERIFY_TOKEN=your_verify_token_random_string
